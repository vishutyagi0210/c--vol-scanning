              "raw": "\"cHduZWQ=\""
            },
            "url": {
              "raw": "{{baseUrl}}/api/pathtraversal/extract?entryName=../../../../tmp/zipslip.txt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pathtraversal", "extract"],
              "query": [
                { "key": "entryName", "value": "../../../../tmp/zipslip.txt" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "XSS / Log Injection",
      "item": [
