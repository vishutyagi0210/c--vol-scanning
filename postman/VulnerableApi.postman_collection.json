        {
          "name": "Redirect - open redirect (CWE-601)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/ssrf/redirect?next=https://evil.example.com",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ssrf", "redirect"],
              "query": [
                { "key": "next", "value": "https://evil.example.com" }
              ]
            },
            "description": "Postman follows redirects by default. Disable redirect-following in Settings to inspect the 302."
          }
        }
      ]
    },
    {
      "name": "Insecure Deserialization",
      "item": [
        {
          "name": "JSON - TypeNameHandling.All gadget (CWE-502)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"{\\\"$type\\\":\\\"System.IO.FileInfo, System.IO.FileSystem\\\",\\\"fileName\\\":\\\"/etc/passwd\\\"}\""
            },
            "url": {
              "raw": "{{baseUrl}}/api/deserialization/json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deserialization", "json"]
            },
            "description": "Demonstrates polymorphic type instantiation through $type. SAST flags the TypeNameHandling.All sink regardless of whether a real gadget chain is reachable on this runtime."
          }
        },
        {
          "name": "Binary - BinaryFormatter (CWE-502)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/octet-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "AAEAAAD/////AQAAAAAAAAAMAgAAAA9TZW5kIGFueSBieXRlcw=="
            },
            "url": {
              "raw": "{{baseUrl}}/api/deserialization/binary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deserialization", "binary"]
            },
            "description": "Sends arbitrary bytes to a BinaryFormatter sink. Will throw at runtime, but the sink itself is the vulnerability scanners flag."
          }
        }
      ]
    },
