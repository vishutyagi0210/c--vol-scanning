          "name": "Hello - reflected XSS (CWE-79)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/xss/hello?name=<script>alert('xss')</script>",
              "host": ["{{baseUrl}}"],
              "path": ["api", "xss", "hello"],
              "query": [
                { "key": "name", "value": "<script>alert('xss')</script>" }
              ]
